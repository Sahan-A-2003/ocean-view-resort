<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20" alignment="CENTER"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.oceanviewresort.controller.LoginController"
      stylesheets="@../css/style.css"
      styleClass="login-container">

    <padding>
        <Insets top="30" right="30" bottom="30" left="30"/>
    </padding>

    <Label text="🌊 Ocean View Resort" styleClass="login-title"/>

    <VBox spacing="10" alignment="CENTER_LEFT" styleClass="form-container">

        <TextField fx:id="usernameField" promptText="Username" styleClass="input-field"/>
        <PasswordField fx:id="passwordField" promptText="Password" styleClass="input-field"/>

    </VBox>

    <Button text="Login" fx:id="loginButton" onAction="#handleLogin" styleClass="login-button"/>

    <Label fx:id="messageLabel" textFill="red" styleClass="message-label"/>

</VBox>